# Backend Configuration - Copy to .env and fill in your values
# NEVER commit .env to GitHub!

# ===== Database =====
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/goal_forge_db

# ===== Authentication =====
# Generate a strong random string (50+ characters)
JWT_SECRET=your_very_secure_random_string_here_min_50_chars

# ===== Email Service (Resend.com) =====
RESEND_API_KEY=re_xxxxxxxxxxxxx

# ===== Frontend Configuration =====
# Used for CORS - set to your Heroku domain after deployment
FRONTEND_URL=http://localhost:3000

# ===== Environment =====
# Options: development, testing, production
ENV=development

# ===== Server =====
# Host and port for FastAPI
HOST=0.0.0.0
PORT=5000

# ===== Security =====
# Enable CORS for frontend
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ===== Logging =====
LOG_LEVEL=INFO
